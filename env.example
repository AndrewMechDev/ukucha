# Copiar este archivo a ".env" (sin extension) y completar los valores.
# ".env" esta en .gitignore -- nunca commitear credenciales reales.

# --- Fuente de datos ---
# UKUCHA_USE_MOCK=1 usa MockTransport (sensores) + MockCameraFeed (video)
# sin necesidad de hardware fisico. Poner en 0 cuando el ESP32-S3 de campo
# y el ESP32-CAM esten encendidos y conectados a la misma red WiFi.
UKUCHA_USE_MOCK=1

# Puertos UDP reales (ver appflores/esp32s3_firmware.ino): el ESP32-S3
# envia telemetria a UKUCHA_TELEMETRY_PORT y escucha comandos en
# UKUCHA_CONTROL_PORT. La IP del nodo se autodetecta del primer paquete
# recibido (DHCP), no hace falta configurarla.
UKUCHA_TELEMETRY_PORT=5002
UKUCHA_CONTROL_PORT=4210

# URL del stream HTTP MJPEG del ESP32-CAM (ver appflores/esp32cam_firmware.ino).
# Ignorado si UKUCHA_USE_MOCK=1. El default abajo asume al ESP32-CAM como
# su propio Access Point (IP fija tipica de modo AP) -- pero la red real
# es el hotspot del celular: el ESP32-CAM se conecta como cliente WiFi y
# recibe una IP por DHCP que puede cambiar entre sesiones. Revisar la IP
# real asignada (lista de dispositivos del hotspot) y actualizar este
# valor a mano en cada sesion. La laptop del backend tambien debe estar
# conectada a ese mismo hotspot (misma subred).
UKUCHA_CAM_URL=http://192.168.4.1/

UKUCHA_ENV_EVERY=5

# --- Persistencia (Fase 5) ---
# Sin estas dos variables, el backend usa NullPersistenceAdapter (no
# persiste nada, pero todo lo demas funciona igual). Completar solo
# cuando exista un proyecto Supabase real con backend/supabase_schema.sql
# ya ejecutado.
SUPABASE_URL=
SUPABASE_KEY=
