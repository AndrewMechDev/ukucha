# Copiar este archivo a ".env" (sin extension) y completar los valores.
# ".env" esta en .gitignore -- nunca commitear credenciales reales.

# --- Fuente de datos (Fase 1-4) ---
# UKUCHA_USE_MOCK=1 usa el simulador de hardware (MockTransport), no
# requiere placas fisicas ni puerto serial. Poner en 0 cuando este el
# ESP32-S3 No3 conectado.
UKUCHA_USE_MOCK=1
UKUCHA_SERIAL_PORT=COM3
UKUCHA_BAUDRATE=115200
UKUCHA_ENV_EVERY=5

# --- Persistencia (Fase 5) ---
# Sin estas dos variables, el backend usa NullPersistenceAdapter (no
# persiste nada, pero todo lo demas funciona igual). Completar solo
# cuando exista un proyecto Supabase real con backend/supabase_schema.sql
# ya ejecutado.
SUPABASE_URL=
SUPABASE_KEY=
